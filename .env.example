# =====================================================================
# Predictive AI Advisor - Environment Configuration Template
# Copy this file to a new file named '.env' and fill in your actual keys.
# DO NOT commit your live '.env' file containing real secrets to GitHub.
# =====================================================================

# 🧠 Foundation AI Model Engines (Provide at least one)
# ---------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_claude_api_key_here

# 🌐 Real-Time Data Stream integrations
# ---------------------------------------------------------------------
NEWS_API_KEY=your_news_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Note: Yahoo Finance (yfinance) integration does not require an API Key.